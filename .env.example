# Copy this file to .env and fill in your keys.
# .env is listed in .gitignore and will never be committed.

# Yelp Fusion API key — get one free at https://www.yelp.com/developers/v3/manage_app
# When set, the app uses Yelp automatically and users never need to paste a key in the UI.
YELP_API_KEY=

# Google Maps / Places API key — get one at https://console.cloud.google.com/apis/credentials
# Requires the "Places API (New)" to be enabled for the project.
GOOGLE_MAPS_API_KEY=
